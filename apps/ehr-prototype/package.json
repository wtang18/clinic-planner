{
  "name": "ehr-prototype",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "build:web": "expo export --platform web",
    "serve:web": "serve dist -p 3001 -s",
    "test:e2e": "npm run build:web && playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "type-check": "tsc --noEmit",
    "storybook": "storybook dev -p 6006 --config-dir ./apps/ehr-prototype/.storybook",
    "build-storybook": "storybook build --config-dir ./apps/ehr-prototype/.storybook"
  },
  "dependencies": {
    "@carbon-health/design-icons": "*",
    "@carbon-health/design-tokens": "*",
    "expo": "~54.0.13",
    "expo-status-bar": "~3.0.8",
    "framer-motion": "^12.29.2",
    "lucide-react": "^0.563.0",
    "nanoid": "^5.1.5",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-native": "0.81.4",
    "react-native-gesture-handler": "^2.28.0",
    "react-native-reanimated": "^4.1.3",
    "react-native-safe-area-context": "^5.6.1",
    "react-native-screens": "^4.16.0",
    "react-native-svg": "^15.14.0",
    "react-native-web": "^0.21.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.52.0",
    "@storybook/addon-a11y": "^9.1.17",
    "@storybook/addon-docs": "^9.1.17",
    "@storybook/react-vite": "^9.1.17",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.0",
    "@vitejs/plugin-react": "^4.4.1",
    "@vitest/coverage-v8": "^3.1.3",
    "@vitest/ui": "^3.1.3",
    "babel-preset-expo": "^54.0.8",
    "jsdom": "^26.1.0",
    "serve": "^14.2.4",
    "storybook": "^9.1.17",
    "typescript": "~5.9.2",
    "vite": "^5.4.21",
    "vitest": "^3.1.3"
  },
  "private": true
}
